NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Sheets Export (service account credentials)
# 1. Go to Google Cloud Console → Create project → Enable Sheets API
# 2. Create Service Account → Download JSON key
# 3. Copy client_email below as GOOGLE_SERVICE_ACCOUNT_EMAIL
# 4. Copy private_key below as GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY (include \n newlines)
# 5. Create a Google Sheet → share it with the service account email (Editor)
# 6. Copy the spreadsheet ID from the URL: docs.google.com/spreadsheets/d/{ID}/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id_here
